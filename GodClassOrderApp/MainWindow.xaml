
<Window x:Class="GodClassOrderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="God Class Order App" Height="400" Width="600">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock>Product:</TextBlock>
            <TextBox x:Name="txtProduct" Margin="0,0,0,5" />
            <TextBlock>Price:</TextBlock>
            <TextBox x:Name="txtPrice" Margin="0,0,0,5" />
            <Button Content="Add Order" Click="AddOrder_Click" Margin="0,0,0,10"/>
            <ListBox x:Name="lstOrders"/>
        </StackPanel>
    </Grid>
</Window>
