
<Window x:Class="FakeLayeredInvoiceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invoice App" Height="350" Width="500">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock>Amount:</TextBlock>
            <TextBox x:Name="txtAmount" Margin="0,0,0,5" />
            <Button Content="Add Invoice" Click="Add_Click" Margin="0,0,0,10"/>
            <ListBox x:Name="lstInvoices"/>
        </StackPanel>
    </Grid>
</Window>
